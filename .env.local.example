# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_PRICE_MONTHLY_ID=
STRIPE_PRO_PRICE_YEARLY_ID=

# WhatsApp Cloud API (Meta)
# Required for all WhatsApp reminders (session reminders, payment chasers, etc.).
# Missing vars throw at startup in production (src/lib/whatsapp.ts).
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Optional — used for template management APIs, not required for sends.
WHATSAPP_WABA_ID=

# Twilio SMS — used for client magic-link login only (NOT WhatsApp reminders).
# Reminders continue to use WHATSAPP_* via Meta Cloud API.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=
