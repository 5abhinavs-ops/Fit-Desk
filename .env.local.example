# =============================================================================
# FitDesk — Environment Variables (example)
# Copy to .env.local and fill in real values. NEVER commit real secrets.
# =============================================================================

# --- Supabase ---------------------------------------------------------------
# Public URL + anon key used by the browser client (RLS-enforced).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (bypasses RLS). Server-only. Never expose to browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (AI) ---------------------------------------------------------
# Used by /api/nutrition/analyse for photo-based nutrition logging.
ANTHROPIC_API_KEY=

# --- Stripe -----------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_PRICE_MONTHLY_ID=
STRIPE_PRO_PRICE_YEARLY_ID=

# --- WhatsApp Cloud API (Meta) ----------------------------------------------
# Required for all WhatsApp reminders (session reminders, payment chasers, etc.).
# Missing vars throw at startup in production (src/lib/whatsapp.ts).
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Optional — used for template management APIs only.
WHATSAPP_BUSINESS_ACCOUNT_ID=

# --- Twilio SMS --------------------------------------------------------------
# Used for client magic-link login ONLY (not for WhatsApp reminders).
# Reminders go through WHATSAPP_* (Meta Cloud API) above.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=

# --- Sentry (error monitoring) ----------------------------------------------
# DSN is public-safe. Server + edge uses SENTRY_DSN, client uses NEXT_PUBLIC_SENTRY_DSN.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Optional — only needed in CI for source-map upload on build.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- App --------------------------------------------------------------------
# Public URL of the deployed app (used in WhatsApp links + Stripe return URLs).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Shared secret required by the Vercel cron -> /api/reminders handler.
CRON_SECRET=
